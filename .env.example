# ============================================
# Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# API Configuration
# ============================================
# Backend API base URL
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_URL=http://localhost:8081/api

# API Timeout (in milliseconds)
VITE_API_TIMEOUT=10000

# ============================================
# Application Environment
# ============================================
# Environment: development, staging, production
VITE_APP_ENV=development

# Application Name
VITE_APP_NAME=FoodDash

# Application Version
VITE_APP_VERSION=1.0.0

# ============================================
# Features & Feature Flags
# ============================================
# Enable/Disable features for testing
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_DEBUG_MODE=false

# ============================================
# Third-party Services
# ============================================
# Google Maps API Key (if using maps)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Stripe Public Key (if using payments)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here

# Firebase Configuration (if using Firebase)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================
# Analytics & Monitoring
# ============================================
# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Google Analytics ID
VITE_GA_ID=

# ============================================
# Logging
# ============================================
# Log Level: error, warn, info, debug, trace
VITE_LOG_LEVEL=info

# ============================================
# Performance
# ============================================
# Image optimization URL (optional)
VITE_IMAGE_OPTIMIZATION_URL=

# Cache duration (in minutes)
VITE_CACHE_DURATION=30

# ============================================
# URLs
# ============================================
# Frontend URL (for redirects)
VITE_FRONTEND_URL=http://localhost:5173

# Support/Help URL
VITE_SUPPORT_URL=https://support.fooddash.com

# Privacy Policy URL
VITE_PRIVACY_POLICY_URL=https://fooddash.com/privacy

# Terms of Service URL
VITE_TERMS_URL=https://fooddash.com/terms
